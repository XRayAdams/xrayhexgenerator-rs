#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Hexgenerator"

#. Menu item
msgid "_About"
msgstr "Om _programmet"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Generator:"

#. Label for digits spin button
msgid "Digits"
msgstr "Siffror"

#. Label for lines spin button
msgid "Lines"
msgstr "Rader"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Utmatning i versaler"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Generera"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "K_opiera till klippbordet"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "Kopierat till klippbordet"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Konstantin Adamov"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Anpassad hex"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "MAC-adress"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Byte sekvens"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Hex-färg"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Hex-färg med alfa"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Prefix-hex"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "EUI-64-identifikator"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "IPv4-adress"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "IPv6-adress"

#. Generator name: Base32 String
msgid "Base32 String"
msgstr "Base32-sträng"

#. Generator name: Short ID (NanoID)
msgid "Short ID (NanoID)"
msgstr "Kort-ID (NanoID)"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Generera olika typer av hexadecimala värden"

#. CLI: -g flag help
msgid "Generator type: {}"
msgstr "Generatortyp: {}"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Antal rader att generera"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Antal siffror (om tillämpligt)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Använd versaler i hexadecimala tecken"

#. CLI: -v flag help
msgid "Print version"
msgstr "Skriv ut version"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Okänd generator: {}. Använder 'custom' i stället."

#. CLI: available generators list
msgid "Available generators: {}"
msgstr "Tillgängliga generatorer: {}"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Ingen generator angiven. Använd -g <typ> för att välja en generator."

#. CLI: -h flag help
msgid "Print help"
msgstr "Skriv ut hjälp"

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "Misslyckades med att initiera GTK"

#. Save to file button (mnemonic)
msgid "_Save to File"
msgstr "_Spara till fil"

#. Toast notification after saving
msgid "Saved to file"
msgstr "Sparat till fil"
