#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Hex generátor"

#. Menu item
msgid "_About"
msgstr "O _aplikaci"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Generátor:"

#. Label for digits spin button
msgid "Digits"
msgstr "Číslice"

#. Label for lines spin button
msgid "Lines"
msgstr "Řádky"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Výstup velkými písmeny"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Vygenerovat"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "_Kopírovat do schránky"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "Zkopírováno do schránky"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Konstantin Adamov"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Vlastní Hex"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "MAC Adresa"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Sekvence bajtů"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Hex barva"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Hex barva s alfa"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Hex s předponou"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "Identifikátor EUI-64"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "IPv4 adresa"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "IPv6 adresa"

#. Generator name: Base32 String
msgid "Base32 String"
msgstr "Base32 řetězec"

#. Generator name: Short ID (NanoID)
msgid "Short ID (NanoID)"
msgstr "Krátké ID (NanoID)"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Generuje různé typy hexadecimálních hodnot"

#. CLI: -g flag help
msgid "Generator type: {}"
msgstr "Typ generátoru: {}"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Počet řádků k vygenerování"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Počet číslic (pouze pro příslušné typy)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Použít velká hexadecimální číslice"

#. CLI: -v flag help
msgid "Print version"
msgstr "Zobrazit verzi"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Neznámý generátor: {}. Místo toho použito 'custom'."

#. CLI: available generators list
msgid "Available generators: {}"
msgstr "Dostupné generátory: {}"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Žádný generátor nebyl zadán. Použijte -g <typ> pro výběr."

#. CLI: -h flag help
msgid "Print help"
msgstr "Zobrazit nápovědu"

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "Nepodařilo se inicializovat GTK"

#. Save to file button (mnemonic)
msgid "_Save to File"
msgstr "_Uložit do souboru"

#. Toast notification after saving
msgid "Saved to file"
msgstr "Uloženo do souboru"
