#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Hex-Generator"

#. Menu item
msgid "_About"
msgstr "_Über"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Generator:"

#. Label for digits spin button
msgid "Digits"
msgstr "Ziffern"

#. Label for lines spin button
msgid "Lines"
msgstr "Zeilen"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Ausgabe in Großbuchstaben"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Generieren"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "_In Zwischenablage kopieren"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "In Zwischenablage kopiert"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Konstantin Adamov"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Benutzerdefiniertes Hex"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "MAC-Adresse"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Bytefolge"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Hex-Farbe"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Hex-Farbe mit Alpha"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Hex mit Präfix"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "EUI-64-Kennung"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "IPv4-Adresse"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "IPv6-Adresse"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Verschiedene Arten von Hexadezimalwerten erzeugen"

#. CLI: -g flag help
msgid "Generator type: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Generatortyp: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Anzahl der zu erzeugenden Zeilen"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Anzahl der Ziffern (falls zutreffend)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Großbuchstaben für Hexadezimalzeichen verwenden"

#. CLI: -v flag help
msgid "Print version"
msgstr "Version ausgeben"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Unbekannter Generator: {}. Verwende stattdessen 'custom'."

#. CLI: available generators list
msgid "Available generators: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Verfügbare Generatoren: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Kein Generator angegeben. Verwende -g <Typ>, um einen Generator auszuwählen."

#. CLI: -h flag help
msgid "Print help"
msgstr "Hilfe anzeigen"

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "GTK konnte nicht initialisiert werden"
