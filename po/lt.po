#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Hex generatorius"

#. Menu item
msgid "_About"
msgstr "_Apie"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Generatorius:"

#. Label for digits spin button
msgid "Digits"
msgstr "Skaitmenys"

#. Label for lines spin button
msgid "Lines"
msgstr "Eilutės"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Išvestis didžiosiomis raidėmis"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Generuoti"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "_Kopijuoti į iškarpinę"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "Nukopijuota į iškarpinę"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Konstantin Adamov"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Pasirinktinis Hex"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "MAC adresas"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Baitų seka"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Hex spalva"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Hex spalva su alfa kanalu"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Hex su prefiksu"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "EUI-64 identifikatorius"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "IPv4 adresas"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "IPv6 adresas"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Generuoti įvairių tipų šešioliktaines reikšmes"

#. CLI: -g flag help
msgid "Generator type: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Generatoriaus tipas: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Eilučių skaičius generavimui"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Skaitmenų skaičius (kur taikoma)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Naudoti didžiąsias šešioliktaines raides"

#. CLI: -v flag help
msgid "Print version"
msgstr "Rodyti versiją"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Nežinomas generatorius: {}. Naudojamas 'custom'."

#. CLI: available generators list
msgid "Available generators: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Galimi generatoriai: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Generatorius nenurodytas. Naudokite -g <tipas> generatoriui pasirinkti."

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "Nepavyko inicializuoti GTK"
