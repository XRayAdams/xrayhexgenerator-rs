#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Hex Oluşturucu"

#. Menu item
msgid "_About"
msgstr "_Hakkında"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Oluşturucu:"

#. Label for digits spin button
msgid "Digits"
msgstr "Basamak Sayısı"

#. Label for lines spin button
msgid "Lines"
msgstr "Satır Sayısı"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Büyük Harfli Çıktı"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Oluştur"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "_Panoya Kopyala"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "Panoya kopyalandı"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Konstantin Adamov"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Özel Hex"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "MAC Adresi"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Bayt Dizisi"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Hex Renk"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Alpha ile Hex Renk"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Önekli Hex"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "EUI-64 Kimliği"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "IPv4 Adresi"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "IPv6 Adresi"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Çeşitli türde hex değerler oluşturun"

#. CLI: -g flag help
msgid "Generator type: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Oluşturucu tipi: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Oluşturulacak satır sayısı"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Basamak sayısı (uygulanabilir durumlarda)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Büyük harfli hex karakterleri kullan"

#. CLI: -v flag help
msgid "Print version"
msgstr "Sürümü yazdır"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Bilinmeyen oluşturucu: {}. Bunun yerine 'custom' kullanılıyor."

#. CLI: available generators list
msgid "Available generators: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Mevcut oluşturucular: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Hiç oluşturucu belirtilmedi. Bir oluşturucu seçmek için -g <tip> kullanın."

#. CLI: -h flag help
msgid "Print help"
msgstr "Yardımı yazdır"

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "GTK başlatılamadı"

#. Save to file button (mnemonic)
msgid "_Save to File"
msgstr "_Dosyaya Kaydet"

#. Toast notification after saving
msgid "Saved to file"
msgstr "Dosyaya kaydedildi"
