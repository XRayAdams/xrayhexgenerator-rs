#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Generatore Hex"

#. Menu item
msgid "_About"
msgstr "_Informazioni"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Generatore:"

#. Label for digits spin button
msgid "Digits"
msgstr "Cifre"

#. Label for lines spin button
msgid "Lines"
msgstr "Righe"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Output in maiuscolo"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Genera"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "_Copia negli appunti"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "Copiato negli appunti"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Konstantin Adamov"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Hex personalizzato"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "Indirizzo MAC"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Sequenza di byte"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Colore Hex"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Colore Hex con alfa"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Hex con prefisso"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "Identificatore EUI-64"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "Indirizzo IPv4"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "Indirizzo IPv6"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Genera vari tipi di valori esadecimali"

#. CLI: -g flag help
msgid "Generator type: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Tipo di generatore: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Numero di righe da generare"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Numero di cifre (dove applicabile)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Usa caratteri esadecimali maiuscoli"

#. CLI: -v flag help
msgid "Print version"
msgstr "Mostra versione"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Generatore sconosciuto: {}. Viene usato 'custom'."

#. CLI: available generators list
msgid "Available generators: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Generatori disponibili: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Nessun generatore specificato. Usa -g <tipo> per selezionare un generatore."

#. CLI: -h flag help
msgid "Print help"
msgstr "Mostra aiuto"

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "Impossibile inizializzare GTK"
