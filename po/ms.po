#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Penjana Hex"

#. Menu item
msgid "_About"
msgstr "_Mengenai"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Penjana:"

#. Label for digits spin button
msgid "Digits"
msgstr "Digit"

#. Label for lines spin button
msgid "Lines"
msgstr "Baris"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Keluaran dalam Huruf Besar"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Jana"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "_Salin ke Papan Kereta"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "Disalin ke papan kereta"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Konstantin Adamov"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Hex Khusus"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "Alamat MAC"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Urutan bait"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Warna Hex"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Warna Hex dengan Alpha"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Hex berawalan"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "Pengecam EUI-64"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "Alamat IPv4"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "Alamat IPv6"

#. Generator name: Base32 String
msgid "Base32 String"
msgstr "Rentetan Base32"

#. Generator name: Short ID (NanoID)
msgid "Short ID (NanoID)"
msgstr "ID Pendek (NanoID)"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Jana pelbagai jenis nilai heksadesimal"

#. CLI: -g flag help
msgid "Generator type: {}"
msgstr "Jenis penjana: {}"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Bilangan baris untuk dijana"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Bilangan digit (jika berkenaan)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Gunakan aksara heksadesimal huruf besar"

#. CLI: -v flag help
msgid "Print version"
msgstr "Cetak versi"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Penjana tidak diketahui: {}. Menggunakan 'custom' pula."

#. CLI: available generators list
msgid "Available generators: {}"
msgstr "Penjana yang tersedia: {}"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Tiada penjana dinyatakan. Gunakan -g <jenis> untuk memilih penjana."

#. CLI: -h flag help
msgid "Print help"
msgstr "Cetak bantuan"

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "Gagal memulakan GTK"

#. Save to file button (mnemonic)
msgid "_Save to File"
msgstr "_Simpan ke Fail"

#. Toast notification after saving
msgid "Saved to file"
msgstr "Disimpan ke fail"
