#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Hex-generator"

#. Menu item
msgid "_About"
msgstr "_Info"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Generator:"

#. Label for digits spin button
msgid "Digits"
msgstr "Cijfers"

#. Label for lines spin button
msgid "Lines"
msgstr "Regels"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Uitvoer in hoofdletters"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Genereren"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "_Kopiëren naar klembord"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "Gekopieerd naar klembord"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Konstantin Adamov"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Aangepaste hex"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "MAC-adres"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Bytevolgorde"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Hex-kleur"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Hex-kleur met alpha"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Hex met voorvoegsel"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "EUI-64-identifier"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "IPv4-adres"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "IPv6-adres"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Verschillende soorten hexadecimale waarden genereren"

#. CLI: -g flag help
msgid "Generator type: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Generatortype: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Aantal regels om te genereren"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Aantal cijfers (indien van toepassing)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Hoofdletters voor hexadecimale tekens gebruiken"

#. CLI: -v flag help
msgid "Print version"
msgstr "Versie weergeven"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Onbekende generator: {}. In plaats daarvan wordt 'custom' gebruikt."

#. CLI: available generators list
msgid "Available generators: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Beschikbare generatoren: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Geen generator opgegeven. Gebruik -g <type> om een generator te selecteren."

#. CLI: -h flag help
msgid "Print help"
msgstr "Help weergeven"

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "Kan GTK niet initialiseren"

#. Save to file button (mnemonic)
msgid "_Save to File"
msgstr "_Opslaan in bestand"

#. Toast notification after saving
msgid "Saved to file"
msgstr "Opgeslagen in bestand"