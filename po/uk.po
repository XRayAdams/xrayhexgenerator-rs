#. Window title / About dialog application name
msgid "Hex Generator"
msgstr "Hex-генератор"

#. Menu item
msgid "_About"
msgstr "_Про програму"

#. Label for generator dropdown
msgid "Generator:"
msgstr "Генератор:"

#. Label for digits spin button
msgid "Digits"
msgstr "Цифри"

#. Label for lines spin button
msgid "Lines"
msgstr "Рядки"

#. Label for uppercase switch
msgid "Output in Uppercase"
msgstr "Вивід у верхньому регістрі"

#. Generate button (mnemonic)
msgid "_Generate"
msgstr "_Згенерувати"

#. Copy to clipboard button (mnemonic)
msgid "_Copy to Clipboard"
msgstr "_Копіювати до буфера обміну"

#. Toast notification after copying
msgid "Copied to clipboard"
msgstr "Скопійовано до буфера обміну"

#. About dialog copyright
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 Костянтин Адамов"

#. Generator name: Custom Hex
msgid "Custom Hex"
msgstr "Довільний Hex"

#. Generator name: MAC Address
msgid "MAC Address"
msgstr "MAC-адреса"

#. Generator name: Byte Sequence
msgid "Byte Sequence"
msgstr "Послідовність байтів"

#. Generator name: GUID
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
msgid "Hex Color"
msgstr "Hex-колір"

#. Generator name: Hex Color with Alpha
msgid "Hex Color with Alpha"
msgstr "Hex-колір з альфа-каналом"

#. Generator name: Prefixed Hex
msgid "Prefixed Hex"
msgstr "Hex з префіксом"

#. Generator name: EUI-64 Identifier
msgid "EUI-64 Identifier"
msgstr "Ідентифікатор EUI-64"

#. Generator name: IPv4 Address
msgid "IPv4 Address"
msgstr "IPv4-адреса"

#. Generator name: IPv6 Address
msgid "IPv6 Address"
msgstr "IPv6-адреса"

#. CLI: about description
msgid "Generate various types of hexadecimal values"
msgstr "Генерація різних типів шістнадцяткових значень"

#. CLI: -g flag help
msgid "Generator type: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Тип генератора: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: -l flag help
msgid "Number of lines to generate"
msgstr "Кількість рядків для генерації"

#. CLI: -d flag help
msgid "Number of digits (where applicable)"
msgstr "Кількість цифр (де застосовно)"

#. CLI: -u flag help
msgid "Use uppercase hexadecimal characters"
msgstr "Використовувати шістнадцяткові символи у верхньому регістрі"

#. CLI: -v flag help
msgid "Print version"
msgstr "Показати версію"

#. CLI: unknown generator error
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "Невідомий генератор: {}. Використовується 'custom'."

#. CLI: available generators list
msgid "Available generators: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"
msgstr "Доступні генератори: custom, mac, eui64, ipv4, ipv6, guid, hexcolor, hexalpha, byteseq, prefixed"

#. CLI: no generator specified error
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "Генератор не вказано. Використовуйте -g <тип> для вибору генератора."

#. CLI: -h flag help
msgid "Print help"
msgstr "Показати довідку"

#. GTK init failure
msgid "Failed to initialize GTK"
msgstr "Не вдалося ініціалізувати GTK"
