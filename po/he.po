#. Window title / About dialog application name
#: src/app.rs src/helpers/actions.rs
msgid "Hex Generator"
msgstr "מפיק הקס"

#. Menu item
#: src/app.rs
msgid "_About"
msgstr "_אודות"

#. Label for generator dropdown
#: src/app.rs
msgid "Generator:"
msgstr "מפיק:"

#. Label for digits spin button
#: src/app.rs
msgid "Digits"
msgstr "ספרות"

#. Label for lines spin button
#: src/app.rs
msgid "Lines"
msgstr "שורות"

#. Label for uppercase switch
#: src/app.rs
msgid "Output in Uppercase"
msgstr "פלט באותיות גדולות"

#. Generate button (mnemonic)
#: src/app.rs
msgid "_Generate"
msgstr "_הפק"

#. Copy to clipboard button (mnemonic)
#: src/app.rs
msgid "_Copy to Clipboard"
msgstr "העתקה ל_לוח גזירים"

#. Toast notification after copying
#: src/app.rs
msgid "Copied to clipboard"
msgstr "הועתק לוח הגזירים"

#. About dialog copyright
#: src/helpers/actions.rs
msgid "© 2025, 26 Konstantin Adamov"
msgstr "© 2025, 26 קונסטנטין אדמוב"

#. Generator name: Custom Hex
#: src/app.rs
msgid "Custom Hex"
msgstr "קס מותאם אישית"

#. Generator name: MAC Address
#: src/app.rs
msgid "MAC Address"
msgstr "כתובת MAC"

#. Generator name: Byte Sequence
#: src/app.rs
msgid "Byte Sequence"
msgstr "רצף בתים"

#. Generator name: GUID
#: src/app.rs
msgid "GUID"
msgstr "GUID"

#. Generator name: Hex Color
#: src/app.rs
msgid "Hex Color"
msgstr "צבע קס"

#. Generator name: Hex Color with Alpha
#: src/app.rs
msgid "Hex Color with Alpha"
msgstr "צבע קס עם אלפא"

#. Generator name: Prefixed Hex
#: src/app.rs
msgid "Prefixed Hex"
msgstr "קס עם קידומת"

#. Generator name: EUI-64 Identifier
#: src/app.rs
msgid "EUI-64 Identifier"
msgstr "זיהוי EUI-64"

#. Generator name: IPv4 Address
#: src/app.rs
msgid "IPv4 Address"
msgstr "כתובת IPv4"

#. Generator name: IPv6 Address
#: src/app.rs
msgid "IPv6 Address"
msgstr "כתובת IPv6"

#. Generator name: Base32 String
msgid "Base32 String"
msgstr "מחרוזת Base32"

#. Generator name: Short ID (NanoID)
msgid "Short ID (NanoID)"
msgstr "מזהה קצר (NanoID)"

#. CLI: about description
#: src/cli.rs
msgid "Generate various types of hexadecimal values"
msgstr "הפק סוגי ערכים הקסדיימליים שונים"

#. CLI: -g flag help
#: src/cli.rs
msgid "Generator type: {}"
msgstr "סוג מפיק: {}"

#. CLI: -l flag help
#: src/cli.rs
msgid "Number of lines to generate"
msgstr "מספר שורות להפקה"

#. CLI: -d flag help
#: src/cli.rs
msgid "Number of digits (where applicable)"
msgstr "מספר ספרות (במקרים רלוונטיים)"

#. CLI: -u flag help
#: src/cli.rs
msgid "Use uppercase hexadecimal characters"
msgstr "השתמש בתווים הקסדיימליים באותיות גדולות"

#. CLI: -v flag help
#: src/cli.rs
msgid "Print version"
msgstr "הדפס גרסה"

#. CLI: unknown generator error
#: src/main.rs
msgid "Unknown generator: {}. Using 'custom' instead."
msgstr "מפיק לא ידוע: {}. משתמש ב-'custom' במקום."

#. CLI: available generators list
#: src/main.rs
msgid "Available generators: {}"
msgstr "מפעים זמינים: {}"

#. CLI: no generator specified error
#: src/main.rs
msgid "No generator specified. Use -g <type> to select a generator."
msgstr "לא נבחר מפיק. השתמש ב- -g <type> כדי לבחור מפיק."

#. CLI: -h flag help
msgid "Print help"
msgstr "הדפס עזרה"

#. GTK init failure
#: src/main.rs
msgid "Failed to initialize GTK"
msgstr "אתחול GTK נכשל"

#. Save to file button (mnemonic)
#: src/app.rs
msgid "_Save to File"
msgstr "_שמור לקובץ"

#. Toast notification after saving
#: src/app.rs
msgid "Saved to file"
msgstr "נשמר לקובץ"
